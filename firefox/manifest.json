{
	"manifest_version": 3,
	"name": "UCP Helper",
	"description": "Упростит проверку UCP заявок! Powered by h1ghway & mayjann & Enotixa Inc.",
	"version": "2.8.2",

	"browser_specific_settings": {
		"gecko": {
			"id": "ucphelper@gambit-rp",
			"strict_min_version": "109.0"
		}
	},

	"icons": {
		"16": "icons/16.png",
		"32": "icons/32.png",
		"48": "icons/48.png",
		"128": "icons/128.png"
	},

	"action": {
		"default_popup": "main.html"
	},

	"options_ui": {
		"page": "options.html",
		"open_in_tab": true
	},

  	"content_scripts": [{
		"matches": ["https://admin.gambit-rp.com/*"],
		"js": ["loader.js"],
		"run_at": "document_idle"
	}],

	"web_accessible_resources": [{
		"resources": [
			"*.js",
			"core/*.js",
			"core/*/*.js",
			"modules/*.js",
			"modules/*/*.js"
		],
		"matches": ["https://admin.gambit-rp.com/*"]
	}],

	"permissions": [
		"storage",
		"tabs",
		"notifications",
		"alarms"
	],

	"host_permissions": [
		"https://admin.gambit-rp.com/*",
		"https://raw.githubusercontent.com/*"
	],

	"background": {
		"scripts": [
			"workers/ucpChecker.js"
		]
	}
}